# Bu faylni ".env" deb nusxalang va o'z qiymatlaringizni qo'ying.
# .env faylini HECH KIMGA bermang va GitHub'ga yuklamang!

# --- Telegram bot ---
# 1) Telegram'da @BotFather ga yozing -> /newbot -> token oling
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGhIJKlmNoPQRstuVWxyz

# 2) O'z chat ID'ingiz. Olish uchun: botingizga biror xabar yozing,
#    keyin brauzerda oching:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    chiqqan javobdagi "chat":{"id": ... } sonini bu yerga qo'ying.
#    Bir nechta qabul qiluvchi bo'lsa, vergul bilan ajrating: 111,222
TELEGRAM_CHAT_ID=123456789
